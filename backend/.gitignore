# =============================================================================
# SECRETS & ENVIRONMENT
# =============================================================================
.env
.env.*
!.env.example          # allow a safe template to be committed

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/

# =============================================================================
# VIRTUAL ENVIRONMENT
# =============================================================================
venv/
.venv/
.env/
ENV/

# =============================================================================
# DJANGO
# =============================================================================
# Local database files (using MySQL in production — SQLite is dev only)
db.sqlite3
db.sqlite3-journal
db.sqlite3.bak
*.bak

# Static files collected for production (generated by collectstatic)
staticfiles/
static_root/
/static/

# Media uploads
media/

# Django migrations — keep these committed (they are source-controlled)
# !**/migrations/*.py

# =============================================================================
# MYSQL / DATABASE
# =============================================================================
*.sql
*.dump
*.mysql

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
test-results/

# =============================================================================
# TYPE CHECKING & LINTING
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
pyrightconfig.json

# =============================================================================
# EDITORS & IDEs
# =============================================================================
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# PyCharm / JetBrains
.idea/
*.iml

# Vim / Emacs
*.sw?
*~
\#*\#

# =============================================================================
# OPERATING SYSTEM
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/



# =============================================================================
# LOGS & TEMP FILES
# =============================================================================
*.log
*.pot
logs/
tmp/
temp/

# =============================================================================
# DEPLOYMENT ARTIFACTS
# =============================================================================
# Render / Railway / Heroku
.render/
Procfile.local

# Docker
*.env.docker
